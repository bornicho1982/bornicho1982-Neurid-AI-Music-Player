{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neurid",
  "mainBinaryName": "neurid-music-player",
  "version": "2.0.0",
  "identifier": "com.neurid.player",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "cd ../.. && pnpm --filter @nuclearplayer/player build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Neurid AI Music Player",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "shortDescription": "Next-gen AI powered music streaming app",
    "longDescription": "Neurid is a smart, privacy-focused music player powered by local AI. Seamlessly integrates local library, streaming sources, and intelligent playlist generation.",
    "copyright": "Copyright 2026 Neurid Project",
    "homepage": "https://neurid-player.com",
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "rpm": {
        "epoch": 0,
        "files": {},
        "release": "1"
      }
    },
    "macOS": {
      "signingIdentity": "-",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczRDk0QzBFODNCNDEyNUUKUldSZUVyU0REa3paYzdTaE9IdlErcjNoTmdyMkNLL0d3alFZTHVMcytxQzJ3K1NJRlFWQlVaYk4K",
      "endpoints": [
        "https://github.com/nukeop/nuclear/releases/latest/download/latest.json"
      ]
    }
  }
}